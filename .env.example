# Email Settings (Gmail example - use App Password, not your real password)
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Twilio SMS Settings (optional - requires A2P 10DLC registration for US outreach)
# Easier alternatives: Salesmsg ($25/mo) or SimpleTexting - they handle compliance
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Optional: Hunter.io for email finding (free tier: 25/month)
HUNTER_API_KEY=your_hunter_api_key

# Optional: Apollo.io API key
APOLLO_API_KEY=your_apollo_api_key

# ─── Multi-Agent Trading System ───
# Anthropic API key (for LLM calibration in prediction agent)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Twitter/X API (for research agent)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# Reddit API (for research agent)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# Telegram Bot (for trade alerts on your phone)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
